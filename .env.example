# ========================================
# FITNESSMANAGEMENT - Environment Variables
# ========================================
# IMPORTANT: Copy this file to '.env' and fill in your actual values
# DO NOT commit the .env file to Git!

# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-change-this-to-random-string
# Set to 1 in production behind HTTPS
SESSION_COOKIE_SECURE=0
# Optional startup verbosity (1 = show detailed startup warnings)
APP_VERBOSE_STARTUP=0

# ==================== PAYMENT GATEWAYS ====================

# STRIPE CONFIGURATION (International Credit/Debit Cards)
STRIPE_PUBLIC_KEY=your_stripe_public_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# JAZZCASH CONFIGURATION (Pakistan - Sandbox)
JAZZCASH_MERCHANT_ID=MC12345
JAZZCASH_PASSWORD=your_password
JAZZCASH_INTEGRITY_SALT=your_integrity_salt
JAZZCASH_RETURN_URL=https://your-domain.com/jazzcash_return
JAZZCASH_URL=https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform/

# EASYPAISA CONFIGURATION (Pakistan)
EASYPAISA_STORE_ID=your_store_id
EASYPAISA_HASH_KEY=your_hash_key
EASYPAISA_RETURN_URL=https://your-domain.com/easypaisa_return
EASYPAISA_URL=https://easypay.easypaisa.com.pk/easypay/Index.jsf

# Google OAuth 2.0
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Wallet API
# Get from: https://console.cloud.google.com/iam-admin/serviceaccounts
# Download service account JSON and save to project folder
# Then set path here
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
WALLET_ISSUER_ID=your-issuer-id


# Admin Emails (comma-separated)
# Users with these emails will have super admin access
ADMIN_EMAILS=admin@gym.com,youremail@example.com

# Email Configuration (Optional - for password reset emails)
# Use Gmail SMTP or any other SMTP server
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Database (PostgreSQL) - for Railway/Render deployment
DATABASE_URL=postgresql://user:password@host:port/database

# Runtime port (usually auto-provided by platform)
# PORT=5000

# Public URL used in SEO files (robots.txt and sitemap.xml)
PUBLIC_BASE_URL=https://fitnessmanagement.com

# Company profile for public landing page
COMPANY_NAME=fitnessmanagement
COMPANY_TAGLINE=Modern SaaS platform for gyms and fitness studios
COMPANY_PHONE=+92-300-0000000
COMPANY_EMAIL=support@fitnessmanagement.com
COMPANY_ADDRESS=Main Boulevard, Lahore, Pakistan
COMPANY_WEBSITE=https://fitnessmanagement.com
